{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "wattpilotKey": {
      "value": "${WATTPILOT_KEY}"
    },
    "containerImage": {
      "value": "${CONTAINER_IMAGE=jetzlstorfer/wattpilot-export:latest}"
    },
    "dockerUsername": {
      "value": "${DOCKER_USERNAME=}"
    },
    "dockerPassword": {
      "value": "${DOCKER_PASSWORD=}"
    },
    "entraClientId": {
      "value": "${ENTRA_CLIENT_ID=}"
    },
    "entraClientSecret": {
      "value": "${ENTRA_CLIENT_SECRET=}"
    },
    "customDomainName": {
      "value": "${CUSTOM_DOMAIN_NAME=}"
    },
    "managedCertificateId": {
      "value": "${MANAGED_CERTIFICATE_ID=}"
    }
  }
}
